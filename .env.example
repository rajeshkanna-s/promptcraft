# ─────────────────────────────────────────────────────────────────────────────
# PromptCraft API configuration
#
# By default PromptCraft talks to a Supabase Edge Function ("ai-chat") that
# proxies to an LLM provider. This keeps real provider keys on the server — the
# value below is a PUBLISHABLE key that is safe to ship in the browser bundle.
#
# Copy this file to `.env` and fill in your own values, then restart `npm run dev`.
# In Vite, only variables prefixed with VITE_ are exposed to client code.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase Edge Function endpoint
VITE_AI_ENDPOINT=https://wuvgoqjxvnbihwiijzfb.supabase.co/functions/v1/ai-chat

# Supabase publishable key (used for both apikey + Authorization headers)
VITE_AI_PUBLISHABLE_KEY=sb_publishable_XwfSIwlW4c35Ejv4nwG6Dg_LkXaK4Z_

# ── Provider preset: NVIDIA (Llama-4 Maverick) ──────────────────────────────
VITE_AI_PROVIDER=nvidia
VITE_AI_MODEL_ID=a34c3d62-5e7d-4504-a009-b689575bdb37
VITE_AI_TOKEN_SLOT_ID=b8ee59ec-62ed-42fb-b77a-09654020b8b3

# ── Alternative preset: OpenRouter ──────────────────────────────────────────
# VITE_AI_PROVIDER=openrouter
# VITE_AI_MODEL_ID=eecca7be-5693-4be4-860c-48055729aeb0
# VITE_AI_TOKEN_SLOT_ID=877fbe3c-eb52-4b9a-a386-ef97a78eb77c
